{% import '_includes/forms.twig' as forms %}

{{ forms.textareaField({
    label: 'System Prompt',
    instructions: 'Sent to the AI as the system role. Supports Twig variables like {{ "{{siteLang}}" }} and {{ "{{entryTitle}}" }}.',
    id: 'basePrompt',
    name: 'basePrompt',
    rows: 8,
    value: settings.basePrompt,
}) }}

{{ forms.autosuggestField({
