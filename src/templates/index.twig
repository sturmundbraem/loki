{% extends "_layouts/cp" %}
{% import '_includes/forms.twig' as forms %}
{% set title = "AI Prompts" %}
{% set readOnly = readOnly ?? not craft.app.config.general.allowAdminChanges %}

{% block contentNotice %}
    {% if readOnly %}
        {{ craft.cp.readOnlyNoticeHtml()|raw }}
    {% endif %}
{% endblock %}

{% block actionButton %}
    {% if not readOnly %}
        <button type="submit" class="btn submit" form="prompts-form">Save prompt settings</button>
    {% endif %}
{% endblock %}

{% block content %}
    <form method="post" id="prompts-form">
        {{ csrfInput() }}
        {{ actionInput('craft-loki/prompts/save') }}
        <h2>Define your custom AI prompts</h2>
        <div class="instructions prompt-help">
            <p>
                DeepL prompts are sent as the API <code>target_lang</code> value. Use the exact syntax from
                <a href="https://developers.deepl.com/api-reference/translate#request-body-descriptions" target="_blank" rel="noopener">DeepL's Translate API docs</a>
                and
                <a href="https://developers.deepl.com/docs/getting-started/supported-languages" target="_blank" rel="noopener">supported languages list</a>,
                for example <code>DE</code>, <code>FR</code>, <code>IT</code>, or <code>EN-GB</code>.
            </p>
        </div>
        {{ forms.editableTable({
            id: 'prompts',
            name: 'prompts',
            static: readOnly,
            cols: {
                uid: {
                    heading: '',
                    type: 'singleline',
                    class: 'uid-col',
                },
                text: {
                    heading: 'PROMPT',
                    type: 'multiline',
                },
                label: {
                    heading: 'LABEL',
                    type: 'singleline',
                },
                provider: {
                    heading: 'PROVIDER',
                    type: 'select',
                    options: [
                        {label: 'OpenAI', value: 'openai'},
                        {label: 'Claude', value: 'claude'},
                        {label: 'DeepL', value: 'deepl'},
                    ],
                },
                createDraft: {
                    heading: 'CREATE DRAFT',
                    type: 'checkbox',
                }
            },
            rows: prompts,
            addRowLabel: 'ADD PROMPT',
            allowAdd: true,
            allowDelete: true,
            allowReorder: true,
            })
        }}

        <hr>
        <h2>Assign prompts to fields</h2>

        <div style="display: flex; gap: 20px;">
            <div style="flex: 1; border: 1px solid #ccc; border-radius: 5px; padding: 10px;">
                <h6>Fields</h6>

                <button type="button" class="btn field-select-btn" data-handle="__allPlainText" style="display:block; width: 100%; margin-bottom: 5px; text-align: left;">
                    All Plaintext fields
                </button>

                <button type="button" class="btn field-select-btn" data-handle="__allCKEditor" style="display:block; width: 100%; margin-bottom: 5px; text-align: left;">
                    All Richtext fields
                </button>

                {% for field in allFields %}
                    <div class="field-list-item" style="display: flex; align-items: center; gap: 6px; margin-bottom: 5px;">
                        <a class="move icon" title="Reorder"></a>
                        <button type="button" class="btn field-select-btn"
                                data-handle="{{ field.handle }}"
                                style="flex: 1; text-align: left;">
                            {{ field.name }}
                        </button>
                    </div>
                {% endfor %}
            </div>

            <div style="flex: 1; border: 1px solid #ccc; border-radius: 5px; padding: 10px;">
                <h6>Prompts</h6>
                <div id="prompt-checkboxes">
                    <p style="color: #999;">Select a field to see its prompts</p>
                </div>
                <div id="hidden-assignments"></div>
            </div>
        </div>

    <input type="hidden" id="field-order-input" name="fieldOrder" value="">

    </form>

    <script>
        function readLivePrompts() {
            if (readOnly) {
                return Object.keys(allPrompts).map(function(uid) {
                    return { uid: uid, label: allPrompts[uid].label };
                });
            }

            var list = [];
            document.querySelectorAll('#prompts > tbody > tr').forEach(function(tr) {
                var uidInput = tr.querySelector('.uid-col textarea');
                var labelInput = tr.querySelector('textarea[name$="[label]"]');
                if (uidInput && uidInput.value && labelInput) {
                    list.push({ uid: uidInput.value, label: labelInput.value });
                }
            });
            return list;
        }

        var allPrompts = {{ promptsByUid|json_encode|raw }};
        var fieldAssignments = {{ fieldAssignments|json_encode|raw }};
        var readOnly = {{ readOnly ? 'true' : 'false' }};

        function assignmentInputName(handle) {
            if (handle === '__allPlainText') {
                return 'bucketAssignments[allPlainText][]';
            }
            if (handle === '__allCKEditor') {
                return 'bucketAssignments[allCKEditor][]';
            }
            return 'fieldAssignments[' + handle + '][]';
        }

        function markAssignmentTouched(hiddenContainer, handle) {
            var marker = document.createElement('input');
            marker.type = 'hidden';
            marker.name = handle === '__allPlainText' || handle === '__allCKEditor'
                ? 'bucketAssignmentsTouched[]'
                : 'fieldAssignmentsTouched[]';
            marker.value = handle === '__allPlainText'
                ? 'allPlainText'
                : (handle === '__allCKEditor' ? 'allCKEditor' : handle);
            marker.dataset.field = handle;
            hiddenContainer.appendChild(marker);
        }

        function persistCurrentAssignments(copyChecked) {
            var container = document.getElementById('prompt-checkboxes');
            var hiddenContainer = document.getElementById('hidden-assignments');
            var currentField = container.dataset.currentField;
            if (readOnly || !currentField) return;

            var oldHidden = hiddenContainer.querySelectorAll('input[data-field="' + currentField + '"]');
            oldHidden.forEach(function(el) { el.remove(); });
            markAssignmentTouched(hiddenContainer, currentField);

            if (!copyChecked) return;

            var inputName = assignmentInputName(currentField);
            var currentChecked = container.querySelectorAll('input[type="checkbox"]:checked');
            currentChecked.forEach(function(cb) {
                var hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = inputName;
                hidden.value = cb.value;
                hidden.dataset.field = currentField;
                hiddenContainer.appendChild(hidden);
            });
        }

        document.querySelectorAll('.field-select-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
            console.log('CLICK', btn.dataset.handle);
            document.querySelectorAll('.field-select-btn').forEach(function(b) { b.classList.remove('is-selected'); });
            btn.classList.add('is-selected');

            var handle = btn.dataset.handle;
            var container = document.getElementById('prompt-checkboxes');
            var hiddenContainer = document.getElementById('hidden-assignments');
            
            // Save current checkboxes as hidden inputs before switching
            var currentChecked = container.querySelectorAll('input[type="checkbox"]:checked');
            var currentField = container.dataset.currentField;
            console.log('[click]', handle, '| was on:', currentField, '| checked now:', Array.from(currentChecked).map(function(cb){return cb.value;}));

            if (!readOnly && currentField) {
                var oldHidden = hiddenContainer.querySelectorAll('input[data-field="' + currentField + '"], input[data-field-visited="' + currentField + '"]');
                oldHidden.forEach(function(el) { el.remove(); });

                // Pick the POST name based on what's currently shown
                var inputName;
                if (currentField === '__allPlainText') {
                    inputName = 'bucketAssignments[allPlainText][]';
                } else if (currentField === '__allCKEditor') {
                    inputName = 'bucketAssignments[allCKEditor][]';
                } else {
                    inputName = 'fieldAssignments[' + currentField + '][]';
                }

                currentChecked.forEach(function(cb) {
                    var hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = inputName;
                    hidden.value = cb.value;
                    hidden.dataset.field = currentField;
                    hiddenContainer.appendChild(hidden);
                });
                var marker = document.createElement('input');
                marker.type = 'hidden';
                marker.dataset.fieldVisited = currentField;
                hiddenContainer.appendChild(marker);
            }
            persistCurrentAssignments(true);

            // Track which field is currently shown
            container.dataset.currentField = handle;
            
            // If this field was already shown + edited this session, recover its state from the hidden inputs
            var hiddenForHandle = hiddenContainer.querySelectorAll('input[data-field="' + handle + '"]');
            var visited = hiddenContainer.querySelector('input[data-field-visited="' + handle + '"]');
            var liveAssigned = null;
            console.log('[restore]', handle, '| visited?', !!visited, '| hidden found:', hiddenForHandle.length, '| liveAssigned:', liveAssigned);
            if (visited || hiddenForHandle.length > 0) {
                liveAssigned = [];
                hiddenForHandle.forEach(function(el) { liveAssigned.push(el.value); });
            }

            // Now that we've captured the state, remove the hidden inputs (they'd duplicate the visible checkboxes we're about to render)
            hiddenForHandle.forEach(function(el) { el.remove(); });
            if (visited) visited.remove();

            // Decide what to read (initial state) and what to write (input name)
            var isChecked, inputName;
                        if (handle === '__allPlainText') {
                var assigned = liveAssigned !== null
                    ? liveAssigned
                    : Object.keys(allPrompts).filter(function(uid) { return allPrompts[uid].allPlainText === '1'; });
                isChecked = function(key) { return assigned.indexOf(key) !== -1; };
                inputName = 'bucketAssignments[allPlainText][]';
            } else if (handle === '__allCKEditor') {
                var assigned = liveAssigned !== null
                    ? liveAssigned
                    : Object.keys(allPrompts).filter(function(uid) { return allPrompts[uid].allCKEditor === '1'; });
                isChecked = function(key) { return assigned.indexOf(key) !== -1; };
                inputName = 'bucketAssignments[allCKEditor][]';
            if (handle === '__allPlainText') {
                isChecked = function(key) { return allPrompts[key] && allPrompts[key].allPlainText === '1'; };
            } else if (handle === '__allCKEditor') {
                isChecked = function(key) { return allPrompts[key] && allPrompts[key].allCKEditor === '1'; };
            } else {
                var assigned = liveAssigned !== null ? liveAssigned : (fieldAssignments[handle] || []);
                isChecked = function(key) { return assigned.indexOf(key) !== -1; };
            }
            inputName = assignmentInputName(handle);

            var html = '';
            readLivePrompts().forEach(function(prompt) {
                var checked = isChecked(prompt.uid) ? 'checked' : '';
                var disabled = readOnly ? 'disabled' : '';
                html += '<label style="display:block; margin-bottom:8px;">'
                    + '<input type="checkbox" name="' + inputName + '" value="' + prompt.uid + '" ' + checked + ' ' + disabled + '> '
                    + (prompt.label || '(unnamed)')
                    + '</label>';
            });
            container.innerHTML = html;
        });
    });

    </script>

    {% js %}
        function serializeFieldOrder() {
            var handles = [];
            document.querySelectorAll('.field-list-item .field-select-btn').forEach(function(btn) {
                handles.push(btn.dataset.handle);
            });
            document.getElementById('field-order-input').value = JSON.stringify(handles);
        }

        serializeFieldOrder();   // pre-populate so a save without dragging still works

        function updatePromptPlaceholder(row) {
            if (!row) return;
            var providerSelect = row.querySelector('select[name$="[provider]"]');
            var promptInput = row.querySelector('textarea[name$="[text]"]');
            if (!providerSelect || !promptInput) return;

            promptInput.placeholder = providerSelect.value === 'deepl' ? 'DeepL: only add target_lang' : '';
        }

        document.querySelectorAll('#prompts tbody tr').forEach(updatePromptPlaceholder);

        document.getElementById('prompts').addEventListener('change', function(event) {
            if (event.target.matches('select[name$="[provider]"]')) {
                updatePromptPlaceholder(event.target.closest('tr'));
            }
        });

        if (!readOnly) {
            new Garnish.DragSort($('.field-list-item'), {
                handle: '.move',
                axis: Garnish.Y_AXIS,
            });

            new MutationObserver(function(mutations) {
                mutations.forEach(function(m) {
                    m.addedNodes.forEach(function(node) {
                        if (node.nodeType !== 1 || node.tagName !== 'TR') return;
                        var uidInput = node.querySelector('.uid-col textarea, .uid-col input');
                        if (uidInput && !uidInput.value) {
                            uidInput.value = Craft.uuid();
                        }
                        updatePromptPlaceholder(node);
                    });
                });
            }).observe(document.querySelector('#prompts tbody'), { childList: true });
        }

        document.getElementById('prompts-form').addEventListener('submit', function() {
            serializeFieldOrder();
            persistCurrentAssignments(false);
        });
    {% endjs %}

    <style>
    .field-select-btn.is-selected {
        background-color: var(--gray-200);
        font-weight: bold;
    }
    .prompt-help {
        font-size: 12px;
        padding-bottom: 16px;
    }
    .prompt-help p {
        margin: 0;
    }
    .prompt-help p + p {
        margin-top: 6px;
    }
    .prompt-help a {
        text-decoration: underline;
    }
    .uid-col { display: none; }
    </style>

{% endblock %}
